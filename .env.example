# Student Management Text-to-SQL API Configuration
# Copy this file to .env and fill in your API keys

# LLM Configuration - Choose one provider: local / modal / openai / anthropic
LLM_PROVIDER=local  # "local", "modal", "openai", or "anthropic"
LLM_MODEL=spider1_qlora_latest  # Path to local model or external model name
LLM_DEVICE=auto  # "auto", "cpu", or "cuda"
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500

# Modal remote inference (used when LLM_PROVIDER=modal)
# MODAL_ENDPOINT_URL=https://your-modal-endpoint.modal.run/generate-sql
# MODAL_API_KEY=your_modal_auth_token_if_needed
# MODAL_TIMEOUT_SECONDS=120

# External API Keys (only needed if using external providers)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=student_management.db

# Security
ALLOW_WRITE_OPERATIONS=true
MAX_QUERY_ROWS=1000